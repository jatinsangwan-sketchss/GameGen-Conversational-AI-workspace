{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "GenerationRecipe",
    "type": "object",
    "required": [
      "project_name",
      "starter_template",
      "target_path",
      "scenes_to_create",
      "scripts_to_create",
      "systems_to_create",
      "ui_to_create",
      "validation_checks"
    ],
    "properties": {
      "project_name": {
        "type": "string"
      },
      "starter_template": {
        "type": "string"
      },
      "target_path": {
        "type": "string"
      },
      "scenes_to_create": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["path", "root_type", "root_name"],
          "properties": {
            "path": { "type": "string" },
            "root_type": { "type": "string" },
            "root_name": { "type": "string" },
            "nodes": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "type"],
                "properties": {
                  "name": { "type": "string" },
                  "type": { "type": "string" },
                  "parent": { "type": "string" },
                  "script_path": { "type": "string" }
                }
              }
            }
          }
        }
      },
      "scripts_to_create": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["path", "role"],
          "properties": {
            "path": { "type": "string" },
            "role": { "type": "string" },
            "scene_owned": { "type": "boolean" },
            "dependencies": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      },
      "systems_to_create": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["path", "role"],
          "properties": {
            "path": { "type": "string" },
            "role": { "type": "string" }
          }
        }
      },
      "ui_to_create": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["scene_path", "purpose"],
          "properties": {
            "scene_path": { "type": "string" },
            "purpose": { "type": "string" }
          }
        }
      },
      "config_files_to_create": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["path", "purpose"],
          "properties": {
            "path": { "type": "string" },
            "purpose": { "type": "string" }
          }
        }
      },
      "validation_checks": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id", "description"],
          "properties": {
            "id": { "type": "string" },
            "description": { "type": "string" }
          }
        }
      },
      "repair_hints": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  }