{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "ValidationReport",
    "type": "object",
    "required": [
      "project_name",
      "status",
      "checks",
      "errors",
      "warnings"
    ],
    "properties": {
      "project_name": {
        "type": "string"
      },
      "status": {
        "type": "string",
        "enum": ["pass", "fail", "partial"]
      },
      "checks": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id", "description", "status"],
          "properties": {
            "id": { "type": "string" },
            "description": { "type": "string" },
            "status": {
              "type": "string",
              "enum": ["pass", "fail", "skip"]
            },
            "details": { "type": "string" }
          }
        }
      },
      "errors": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["type", "message"],
          "properties": {
            "type": { "type": "string" },
            "message": { "type": "string" },
            "file": { "type": "string" },
            "node_path": { "type": "string" },
            "suggested_category": { "type": "string" }
          }
        }
      },
      "warnings": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["message"],
          "properties": {
            "message": { "type": "string" },
            "file": { "type": "string" }
          }
        }
      },
      "debug_output_excerpt": {
        "type": "string"
      },
      "generated_at": {
        "type": "string"
      }
    }
  }