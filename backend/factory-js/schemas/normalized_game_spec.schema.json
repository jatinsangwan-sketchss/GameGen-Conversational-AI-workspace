{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "NormalizedGameSpec",
    "type": "object",
    "required": [
      "project_name",
      "platform",
      "orientation",
      "genre",
      "core_loop",
      "input_model",
      "fail_condition",
      "score_model",
      "scenes",
      "ui",
      "entities",
      "out_of_scope",
      "acceptance_criteria"
    ],
    "properties": {
      "project_name": {
        "type": "string"
      },
      "platform": {
        "type": "string",
        "enum": ["android", "ios", "pc", "web"]
      },
      "orientation": {
        "type": "string",
        "enum": ["portrait", "landscape"]
      },
      "genre": {
        "type": "string"
      },
      "summary": {
        "type": "string"
      },
      "core_loop": {
        "type": "string"
      },
      "player_fantasy": {
        "type": "string"
      },
      "input_model": {
        "type": "object",
        "required": ["type", "rules"],
        "properties": {
          "type": {
            "type": "string"
          },
          "rules": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "fail_condition": {
        "type": "string"
      },
      "score_model": {
        "type": "string"
      },
      "difficulty_model": {
        "type": "string"
      },
      "scenes": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["name", "purpose"],
          "properties": {
            "name": { "type": "string" },
            "purpose": { "type": "string" }
          }
        }
      },
      "ui": {
        "type": "object",
        "required": ["screens", "hud_elements"],
        "properties": {
          "screens": {
            "type": "array",
            "items": { "type": "string" }
          },
          "hud_elements": {
            "type": "array",
            "items": { "type": "string" }
          },
          "layout_notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "entities": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["name", "role"],
          "properties": {
            "name": { "type": "string" },
            "role": { "type": "string" },
            "behavior_notes": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      },
      "systems": {
        "type": "array",
        "items": { "type": "string" }
      },
      "out_of_scope": {
        "type": "array",
        "items": { "type": "string" }
      },
      "acceptance_criteria": {
        "type": "array",
        "items": { "type": "string" }
      },
      "open_questions": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  }